# Copy this file to .env and fill in the actual values.
# .env is git-ignored and will NOT be committed.

# ─────────────────────────────────────────────
# Google Search Console verification
# ─────────────────────────────────────────────
# How to obtain:
# 1. Go to https://search.google.com/search-console
# 2. Add property → URL prefix → https://studyau.au
# 3. Choose the "HTML tag" method, copy the content value from
#    <meta name="google-site-verification" content="XXXXXX"/>
# 4. Paste XXXXXX below (without quotes).
# 5. Deploy, then return to GSC and click "Verify".
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────
# Cloudflare Web Analytics (optional)
# ─────────────────────────────────────────────
# In the Cloudflare dashboard: Analytics → Web Analytics → Add a site.
# Cloudflare provides <script ... data-cf-beacon='{"token":"xxx"}'></script>.
# Paste the token below (not wired up in Layout.astro yet; add when needed).
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# ─────────────────────────────────────────────
# Bing Webmaster Tools (optional)
# ─────────────────────────────────────────────
# Same flow as GSC. Copy the meta content value from
# <meta name="msvalidate.01" content="XXX"/>.
PUBLIC_BING_VERIFICATION=
