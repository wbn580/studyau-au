# 复制本文件为 .env，填入实际值后即可生效。
# .env 已经在 .gitignore 里，不会被提交到仓库。

# ─────────────────────────────────────────────
# Google Search Console 验证
# ─────────────────────────────────────────────
# 获取方式：
# 1. 打开 https://search.google.com/search-console
# 2. 添加资源 → URL 前缀 → 填 https://studyuk.cn
# 3. 选择"HTML 标记"方式，复制 <meta name="google-site-verification" content="XXXXXX"/> 里的 content 值
# 4. 把 XXXXXX 粘贴到下面的等号右边（不要带引号）
# 5. 部署后回到 GSC 点"验证"
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────
# Cloudflare Web Analytics（可选）
# ─────────────────────────────────────────────
# 在 Cloudflare Pages 后台：Analytics → Web Analytics → Add a site
# Cloudflare 会给你一段 <script ... data-cf-beacon='{"token":"xxx"}'></script>
# 把 token 值填到下面（目前代码里尚未使用，后续如需接入可读取）：
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# ─────────────────────────────────────────────
# Bing Webmaster Tools（可选）
# ─────────────────────────────────────────────
# 方式同 GSC，meta 标签 <meta name="msvalidate.01" content="XXX"/>
PUBLIC_BING_VERIFICATION=

# ─────────────────────────────────────────────
# 百度搜索资源平台（中国大陆 SEO 必备）
# ─────────────────────────────────────────────
# 1. 打开 https://ziyuan.baidu.com → 用户中心 → 站点管理 → 添加网站
# 2. 填入 https://studyuk.cn，选"HTML 标签"方式验证
# 3. 复制 <meta name="baidu-site-verification" content="codeva-XXX"/> 的 content
# 4. 验证通过后记得"普通收录"里手动提交一次 sitemap-index.xml
PUBLIC_BAIDU_VERIFICATION=

# ─────────────────────────────────────────────
# 搜狗站长平台（可选）
# ─────────────────────────────────────────────
# 1. 打开 https://zhanzhang.sogou.com
# 2. 添加站点 → 选"meta 文件验证"
# 3. 复制 <meta name="sogou_site_verification" content="XXX"/> 的 content
PUBLIC_SOGOU_VERIFICATION=

# ─────────────────────────────────────────────
# 360 站长平台（可选）
# ─────────────────────────────────────────────
# 1. 打开 https://zhanzhang.so.com
# 2. 添加网站 → "HTML 标签验证"
# 3. 复制 <meta name="360-site-verification" content="XXX"/> 的 content
PUBLIC_360_VERIFICATION=

# ─────────────────────────────────────────────
# 神马搜索站长平台（UC / 夸克浏览器流量，可选）
# ─────────────────────────────────────────────
# 1. 打开 https://zhanzhang.sm.cn
# 2. 添加网站 → "HTML 标签验证"
# 3. 复制 <meta name="shenma-site-verification" content="XXX"/> 的 content
PUBLIC_SHENMA_VERIFICATION=
