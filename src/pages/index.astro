---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { slugifyTag } from "@/utils/tagSlug";

// ---------- data ----------
const posts = await getCollection("blog");
const sorted = getSortedPosts(posts);

// Gear patches · 6 类目
const tagCount = (tag: string) =>
  posts.filter(
    p => !p.data.draft && (p.data.tags ?? []).includes(tag)
  ).length;

const patches = [
  { emoji: "🪸", label: "Universities", tag: "大学", tone: "maple" },
  { emoji: "🛂", label: "Visa / 500", tag: "签证", tone: "pine" },
  { emoji: "🏠", label: "Arrival & Life", tag: "新生", tone: "sky" },
  { emoji: "💰", label: "Tuition / Cost", tag: "预算", tone: "sun" },
  { emoji: "🏝️", label: "State Choice", tag: "城市", tone: "bark" },
  { emoji: "🛫", label: "485 / PR", tag: "移民", tone: "maple-2" },
];

// Logbook categorization
const TAG_TO_CAT: {
  match: (tags: string[]) => boolean;
  cat: { key: string; emoji: string; label: string };
}[] = [
  {
    match: t =>
      t.some(x =>
        [
          "签证","拒签","GS","CAS","OSHC","Stamp 1G","485","IHS","UKVI","学签",
          "F-1","I-20","EMGS","VAL","IANG","STP","Student 500","PGWP","Study Permit",
        ].includes(x)
      ),
    cat: { key: "visa", emoji: "🛂", label: "签证" },
  },
  {
    match: t => t.some(x => ["住宿","落地","新生","银行","医保"].includes(x)),
    cat: { key: "life", emoji: "🏠", label: "落地" },
  },
  {
    match: t =>
      t.some(x =>
        [
          "移民","工签","技术移民","投资移民","Graduate Route","PSW","PGWP",
          "OPT","H1B","EB-2","LTVP","EP","PR",
        ].includes(x)
      ),
    cat: { key: "job", emoji: "💼", label: "工签" },
  },
  {
    match: t => t.some(x => ["预算","学费","生活费"].includes(x)),
    cat: { key: "money", emoji: "💰", label: "预算" },
  },
  {
    match: t => t.some(x => ["多国联申"].includes(x)),
    cat: { key: "multi", emoji: "🌏", label: "联申" },
  },
  {
    match: t =>
      t.some(x =>
        [
          "大学","选校","八大","G5","罗素","NUS","NTU","分校",
          "英澳分校","K12","中小学","副学士","Ivy","港八大","公立五校",
        ].includes(x)
      ),
    cat: { key: "uni", emoji: "🎓", label: "院校" },
  },
  {
    match: t => t.some(x => ["语言考试","雅思","托福","TOEFL","IELTS","SAT","GRE","GMAT"].includes(x)),
    cat: { key: "lang", emoji: "🗣", label: "语言" },
  },
];

function categorize(tags: string[] | undefined) {
  const t = tags ?? [];
  for (const m of TAG_TO_CAT) if (m.match(t)) return m.cat;
  return { key: "other", emoji: "📌", label: "其它" };
}

function fmtDate(d: Date | undefined | null) {
  if (!d) return "";
  const dd = new Date(d);
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${pad(dd.getDate())}.${pad(dd.getMonth() + 1)}.${dd.getFullYear()}`;
}

const logbook = sorted.slice(0, 8).map((p, i) => ({
  n: String(i + 1).padStart(2, "0"),
  title: p.data.title,
  sub: p.data.description,
  cat: categorize(p.data.tags),
  when: fmtDate(p.data.modDatetime ?? p.data.pubDatetime),
  href: getPath(p.id, p.filePath),
}));

const totalCount = posts.filter(p => !p.data.draft).length;

// Basecamps · 4 signature universities
const basecamps = [
  { flag: "MEL", rank: "#13", zh: "University of Melbourne", en: "Uni Melbourne", bits: ["QS #13", "Go8", "VIC regional"], href: "/tags/%E6%BE%B3%E6%B4%B2%E7%95%99%E5%AD%A6/" },
  { flag: "SYD", rank: "#18", zh: "University of Sydney", en: "USYD", bits: ["QS #18", "Go8", "485 3yr"], href: "/tags/%E6%BE%B3%E6%B4%B2%E7%95%99%E5%AD%A6/" },
  { flag: "SYD", rank: "#19", zh: "UNSW Sydney", en: "UNSW", bits: ["QS #19", "Go8", "Scientia"], href: "/tags/%E6%BE%B3%E6%B4%B2%E7%95%99%E5%AD%A6/" },
  { flag: "ANU", rank: "#30", zh: "Australian National University", en: "ANU", bits: ["QS #30", "Go8", "Canberra"], href: "/tags/%E6%BE%B3%E6%B4%B2%E7%95%99%E5%AD%A6/" },
];

// CTAs preserved per-site
const MIKECRM_URL = "https://www.mikecrm.com/srw6z8S";
const WECHAT_URL = "/about/";
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index">
    <!-- ========== HERO ========== -->
    <section class="hero">
      <div class="hero-inner">
        <div>
          <span class="hero-eyebrow">FIELD NOTES · 2026 AU APPLICATION ATLAS</span>
          <h1>
            From the Reef<br />
            to the<span class="maple">Red Centre</span><br />
            we map the route.
          </h1>
          <p class="hero-sub">
            StudyAU is an independent editorial desk publishing long-form field notes on the Australian study route — from CoE through Student 500 lodgement to 485 graduate visas. {totalCount} entries, cross-checked against MARA, Home Affairs, TEQSA and Study Australia.
          </p>
          <div class="hero-trail">
            <div class="tstep c1"><span class="dot"></span>Choose Uni</div>
            <span class="tsep">→</span>
            <div class="tstep c2"><span class="dot"></span>Offer / CoE</div>
            <span class="tsep">→</span>
            <div class="tstep c3"><span class="dot"></span>Student 500</div>
            <span class="tsep">→</span>
            <div class="tstep c4"><span class="dot"></span>485 Grad Route</div>
          </div>
          <div class="hero-ctas">
            <a
              href={MIKECRM_URL}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="btn-primary"
            >
              🎒 Free Field Assessment <span>→</span>
            </a>
            <a href="/about/" class="btn-ghost">
              💬 Learn more
            </a>
          </div>
          <p class="hero-fineprint">
            Independent editorial · Sources: MARA / Home Affairs / Study Australia / TEQSA
          </p>
        </div>

        <div class="postcards" aria-hidden="true">
          <div class="pc pc-1">
            <div class="pc-img pc-img-photo">
              <svg viewBox="0 0 280 110" preserveAspectRatio="xMidYMid slice"><rect width="280" height="110" fill="var(--sky)" opacity="0.35"/><circle cx="225" cy="28" r="12" fill="var(--sun)" opacity="0.9"/><path d="M100 78 Q120 42 140 78 Z" fill="var(--card)"/><path d="M125 78 Q145 48 165 78 Z" fill="var(--card)" opacity="0.92"/><path d="M150 78 Q170 52 190 78 Z" fill="var(--card)" opacity="0.88"/><path d="M0 82 Q 80 74 160 80 T 280 78 L 280 110 L 0 110 Z" fill="var(--maple)" opacity="0.55"/><path d="M0 95 Q 80 88 160 92 T 280 90 L 280 110 L 0 110 Z" fill="var(--ink)" opacity="0.5"/></svg>
              <div class="pc-stamp">SYD</div>
            </div>
            <h4>Sydney · Under the Bridge</h4>
            <p>UNSW / USYD / Macquarie — Go8 choices, ESOS rules, 485 three-year work rights.</p>
            <div class="pc-meta">POSTED · 02 MAR 2026</div>
          </div>
          <div class="pc pc-2">
            <div class="pc-img pc-img-photo">
              <svg viewBox="0 0 280 110" preserveAspectRatio="xMidYMid slice"><rect width="280" height="110" fill="var(--sky)" opacity="0.25"/><rect x="40" y="30" width="22" height="55" fill="var(--maple)"/><rect x="70" y="47" width="18" height="38" fill="var(--ink)"/><rect x="94" y="17" width="24" height="68" fill="var(--maple-2)"/><rect x="124" y="40" width="16" height="45" fill="var(--sky)"/><rect x="146" y="13" width="22" height="72" fill="var(--ink)"/><rect x="174" y="35" width="18" height="50" fill="var(--maple)"/><rect x="198" y="25" width="26" height="60" fill="var(--ink)"/><rect x="228" y="43" width="14" height="42" fill="var(--maple-2)"/><line x1="0" y1="92" x2="280" y2="92" stroke="var(--ink)" stroke-width="1" opacity="0.7"/><line x1="0" y1="98" x2="280" y2="98" stroke="var(--ink)" stroke-width="1" opacity="0.55"/></svg>
              <div class="pc-stamp">MEL</div>
            </div>
            <h4>Melbourne · Laneway Lights</h4>
            <p>Melbourne Uni / Monash / RMIT — coffee capital + VIC regional points.</p>
            <div class="pc-meta">POSTED · 26 FEB 2026</div>
          </div>
          <div class="pc pc-3">
            <div class="pc-img pc-img-photo">
              <svg viewBox="0 0 280 110" preserveAspectRatio="xMidYMid slice"><rect width="280" height="60" fill="var(--sun)" opacity="0.35"/><rect y="60" width="280" height="50" fill="var(--sky)" opacity="0.4"/><circle cx="210" cy="32" r="15" fill="var(--sun)"/><path d="M0 85 Q 140 72 280 85 L 280 110 L 0 110 Z" fill="var(--maple)" opacity="0.55"/><path d="M50 85 L 48 60 Q 50 52 58 54 Q 60 52 56 58 Q 64 52 62 60 Q 72 55 60 62 L 58 85 Z" fill="var(--ink)"/></svg>
              <div class="pc-stamp">PER</div>
            </div>
            <h4>Perth · Indian Ocean Coast</h4>
            <p>UWA / Curtin / Murdoch — regional DAMA, mining boom, PR shortcut.</p>
            <div class="pc-meta">POSTED · 28 JAN 2026</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== GEAR / CATEGORIES ========== -->
    <section class="section">
      <div class="section-head">
        <div class="section-title">
          <span class="kicker">Field Kit · Gear</span>
          <h2>by <span class="hand">category</span></h2>
        </div>
        <a class="section-see" href="/tags/">All tags →</a>
      </div>
      <div class="patches">
        {patches.map(p => (
          <a class={`patch patch-${p.tone}`} href={`/tags/${slugifyTag(p.tag)}/`}>
            <span class="emoji">{p.emoji}</span>
            <h4>{p.label}</h4>
            <div class="count mono">{tagCount(p.tag)} 篇</div>
          </a>
        ))}
      </div>
    </section>

    <!-- ========== TRAIL SPOTLIGHT ========== -->
    <section class="section pt-10">
      <div class="trail">
        <div class="trail-inner">
          <div class="trail-left">
            <div class="kicker kicker-sun">THIS WEEK'S TRAIL · Coastal Route</div>
            <h2>Australia Student 500<br />30 weeks from offer to arrival</h2>
            <p>
              The real AU timeline, week by week: from shortlisting across Go8 / regional unis / TAFE, through CoE and GTE evidence, to Student 500 lodgement and OSHC activation. Each week below is a checkpoint based on live admissions cycles.
            </p>
            <a class="trail-cta" href="/posts/">
              Read the Full Field Note <span>→</span>
            </a>
          </div>
          <div class="trail-log">
            <h5>
              <span>⛺ Checkpoint Log</span>
              <span class="mono" style="opacity:.6">0 / 6</span>
            </h5>
            <ul>
              <li><span class="kp done">✓</span><span class="wk mono">WK 1-2</span><span><b>Shortlist + Budget</b> · Three tiers, urban / regional / TAFE</span></li>
              <li><span class="kp done">✓</span><span class="wk mono">WK 3-6</span><span><b>Applications Lodged</b> · PS / CV / Reference across 4-6 unis</span></li>
              <li><span class="kp">3</span><span class="wk mono">WK 7-16</span><span><b>Offers Received</b> · Pay COE deposit · GS letter</span></li>
              <li><span class="kp">4</span><span class="wk mono">WK 17-22</span><span><b>IELTS / GTE / Evidence</b> · Financial capacity · OSHC</span></li>
              <li><span class="kp">5</span><span class="wk mono">WK 23-28</span><span><b>Student 500 Lodged</b> · Biometrics · Health check</span></li>
              <li><span class="kp">6</span><span class="wk mono">WK 29-30</span><span><b>Housing · Landing</b> · OSHC activation · SIM · airport pickup</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== LOGBOOK ========== -->
    <section class="section">
      <div class="section-head">
        <div class="section-title">
          <span class="kicker">Logbook · Q&A</span>
          <h2>Latest<span class="hand"> entries</span></h2>
        </div>
        <a class="section-see" href="/posts/">Browse all {totalCount} entries →</a>
      </div>
      <div class="logbook">
        <div class="logbook-head mono">
          <span><span class="dot"></span>LIVE · {totalCount} Q&amp;A · UPDATED DAILY</span>
          <span>// ADMIN: StudyAU editorial</span>
        </div>
        {logbook.map(row => (
          <a class="log-row" href={row.href}>
            <span class="n mono">№ {row.n}</span>
            <div class="log-title">
              <h5>{row.title}</h5>
              <div class="lr-sub">{row.sub}</div>
            </div>
            <span class={`cat cat-${row.cat.key}`}>{row.cat.emoji} {row.cat.label}</span>
            <span class="when mono">📍 {row.when}</span>
            <span class="arrow">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ========== BASECAMPS ========== -->
    <section class="section">
      <div class="section-head">
        <div class="section-title">
          <span class="kicker">Basecamps</span>
          <h2>Go8 field<span class="hand"> campuses</span></h2>
        </div>
        <a class="section-see" href="/tags/">All uni tags →</a>
      </div>
      <div class="schools">
        {basecamps.map(s => (
          <a class="sbox" href={s.href}>
            <span class="flag mono">{s.flag}</span>
            <div class="rank"><small>QS '26</small>{s.rank}</div>
            <h4>{s.zh}</h4>
            <div class="en mono">{s.en}</div>
            <div class="bits">
              {s.bits.map(b => <span>{b}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ========== CAMPFIRE CTA ========== -->
    <section class="campfire">
      <div class="cf">
        <div class="cf-left">
          <div class="cf-kicker">⛱ BEACH FIRE · FIELD Q&A</div>
          <h2>Not sure which coast?<br /><span class="sun">We'll walk the shoreline with you.</span></h2>
          <p>
            Send us your GPA / IELTS / budget / intended major. Within 48 hours we'll send back a field report — three Go8 + three regional options, with visa timeline and 485 / PR projection, cross-checked against Home Affairs and university-official intakes.
          </p>
          <div class="cf-buttons">
            <a
              href={MIKECRM_URL}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="primary"
            >
              🎒 Free Field Assessment <span>→</span>
            </a>
            <a
              href={WECHAT_URL}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="ghost"
            >
              💬 WeChat · Liam
            </a>
          </div>
        </div>
        <div class="cf-right">
          <div class="contact-card">
            <div class="cc-badge">STUDYAU · COASTAL FIELD NOTES</div>
            <h5>Australia study notes</h5>
            <p>Independent editorial · Official-source verified</p>
            <a class="cc-link" href="/about/">About StudyAU →</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* studyau-au Trail Guide · Homepage layout. Tokens come from global.css. */
  main {
    font-family: var(--font-app);
    color: var(--ink);
  }
  .hand { font-family: var(--font-hand); font-weight: 700; }
  .mono { font-family: var(--font-mono); }

  /* HERO */
  .hero { max-width: 1280px; margin: 10px auto 0; padding: 10px 28px 40px; position: relative; }
  .hero-inner { display: grid; grid-template-columns: 1.35fr 1fr; gap: 48px; align-items: center; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--sun); color: var(--ink);
    font-weight: 800; font-size: 12px; padding: 6px 14px;
    border-radius: 999px; border: 1.5px solid var(--ink);
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .hero-eyebrow::before { content: "⛰"; font-size: 14px; }
  .hero h1 {
    font-size: clamp(40px, 5.4vw, 76px); font-weight: 900;
    letter-spacing: -0.03em; line-height: 1.02;
    margin: 18px 0 0; text-wrap: balance; color: var(--ink);
  }
  .hero h1 .maple { color: var(--maple); position: relative; display: inline-block; }
  .hero h1 .maple::after {
    content: ""; position: absolute; left: -4px; right: -4px; bottom: 6px;
    height: 14px; background: var(--sun); z-index: -1;
    opacity: 0.85; transform: rotate(-1deg);
  }
  .hero-sub {
    font-size: 18px; color: var(--ink-2);
    max-width: 54ch; margin: 22px 0 26px;
    line-height: 1.6; text-wrap: pretty;
  }
  .hero-sub b { color: var(--ink); font-weight: 800; }
  .hero-trail { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-bottom: 26px; }
  .tstep {
    background: var(--card); border: 1.5px solid var(--ink); border-radius: 999px;
    padding: 7px 14px; font-size: 13px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 6px;
    box-shadow: 2px 2px 0 var(--ink);
  }
  .tstep .dot { width: 8px; height: 8px; border-radius: 50%; }
  .tstep.c1 .dot { background: var(--blue); }
  .tstep.c2 .dot { background: var(--sun); }
  .tstep.c3 .dot { background: var(--sky); }
  .tstep.c4 .dot { background: var(--maple); }
  .tsep { font-size: 16px; color: var(--ink-3); }

  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--maple); color: var(--cream);
    border: 2px solid var(--ink); box-shadow: 4px 4px 0 var(--ink);
    font-family: inherit; font-weight: 800; font-size: 15px;
    padding: 14px 22px; border-radius: 12px; cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px;
    transition: transform 0.15s; text-decoration: none;
  }
  .btn-primary:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 var(--ink); }
  .btn-ghost {
    background: var(--cream); color: var(--ink);
    border: 2px solid var(--ink); font-family: inherit;
    font-weight: 800; font-size: 15px; padding: 14px 22px;
    border-radius: 12px; cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
  }
  .btn-ghost:hover { background: var(--card); }
  .hero-fineprint {
    margin-top: 22px; font-size: 12px; color: var(--ink-3);
    letter-spacing: 0.02em;
  }

  /* postcards */
  .postcards { position: relative; height: 500px; }
  .pc {
    position: absolute; background: var(--card);
    border: 2px solid var(--ink); border-radius: 14px;
    box-shadow: 5px 5px 0 var(--ink); padding: 18px;
    width: 280px; display: flex; flex-direction: column; gap: 10px;
  }
  .pc-1 { top: 10px; left: 40px; transform: rotate(-4deg); }
  .pc-2 { top: 100px; right: 0; transform: rotate(3deg); width: 260px; }
  .pc-3 { bottom: 20px; left: 10px; transform: rotate(-1deg); width: 300px; }
  .pc-stamp {
    position: absolute; top: 12px; right: 12px;
    width: 44px; height: 54px;
    background: repeating-linear-gradient(45deg, var(--maple) 0 4px, var(--maple-2) 4px 8px);
    border: 1.5px solid var(--ink); border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    color: var(--cream); font-weight: 900; font-size: 11px;
    letter-spacing: 0.05em; transform: rotate(4deg);
  }
  .pc-img { height: 130px; border-radius: 8px; border: 1.5px solid var(--ink); position: relative; overflow: hidden; background: var(--card); }
  .pc-img-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .pc-img :global(svg) { position: absolute; inset: 0; width: 100%; height: 100%; }
  .pc h4 { font-size: 16px; font-weight: 900; margin: 0; line-height: 1.2; letter-spacing: -0.015em; color: var(--ink); }
  .pc p { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.5; }
  .pc .pc-meta { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.05em; }

  /* SECTION */
  .section { max-width: 1280px; margin: 0 auto; padding: 56px 28px; }
  .section.pt-10 { padding-top: 10px; }
  .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 30px; }
  .section-title { display: flex; flex-direction: column; gap: 4px; }
  .kicker {
    font-size: 12px; letter-spacing: 0.3em;
    color: var(--maple); font-weight: 800;
    text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .kicker::before { content: "✦"; color: var(--sun); font-size: 16px; }
  .kicker-sun { color: var(--sun); }
  .kicker-sun::before { color: var(--sun); }
  .section-title h2 {
    font-size: 40px; font-weight: 900; letter-spacing: -0.03em;
    line-height: 1; margin: 0; color: var(--ink);
  }
  .section-title h2 .hand {
    font-size: 54px; color: var(--blue); margin-left: 8px;
    display: inline-block; transform: rotate(-2deg);
  }
  .section-see {
    font-size: 14px; font-weight: 700; color: var(--ink);
    border-bottom: 2px solid var(--maple); padding-bottom: 2px;
    text-decoration: none; white-space: nowrap;
  }

  /* PATCHES */
  .patches { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
  .patch {
    background: var(--card); border: 2px solid var(--ink);
    border-radius: 16px; padding: 18px 14px; text-align: center;
    box-shadow: 3px 3px 0 var(--ink); cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    position: relative; overflow: hidden;
    text-decoration: none; color: inherit;
  }
  .patch::before {
