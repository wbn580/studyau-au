---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { slugifyTag } from "@/utils/tagSlug";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// 5 primary categories — tag values must match article frontmatter tags.
const categories = [
  { emoji: "🎓", name: "Universities", desc: "Go8 / ATN / rankings" },
  { emoji: "📚", name: "Courses", desc: "Business / STEM / Health" },
  { emoji: "🛂", name: "Visa", desc: "Subclass 500 / GS / IELTS" },
  { emoji: "🏠", name: "Living", desc: "Housing / OSHC / costs" },
  { emoji: "💼", name: "Post-Study", desc: "485 / PR / jobs" },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Your complete guide to studying in Australia.
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="RSS feed"
        title="RSS feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS feed</span>
      </a>

      <p>
        <strong>StudyAU</strong> is a plain-English knowledge base for international
        students planning to study in Australia — from Group of Eight and ATN
        university selection, to the Student Visa (subclass 500), Genuine Student
        requirement, IELTS/PTE pathways, accommodation, cost of living, and the
        Temporary Graduate Visa (subclass 485). We work from Department of Home
        Affairs, Department of Education, and university sources, and we update
        whenever policy changes.
      </p>
      <p class="mt-2">
        Browse a category below or read
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/about/"
        >
          about this site
        </LinkButton> for our editorial approach.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Contact:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="categories" class="pt-12 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide">Browse by category</h2>
      <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {categories.map(c => (
          <li>
            <a
              href={`/tags/${slugifyTag(c.name)}/`}
              class="flex items-center gap-3 rounded-md border border-border px-4 py-3 hover:border-accent hover:text-accent transition"
            >
              <span class="text-2xl">{c.emoji}</span>
              <span class="flex min-w-0 flex-col">
                <span class="font-medium">{c.name}</span>
                <span class="truncate text-xs whitespace-nowrap text-foreground/60">{c.desc}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured guides</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent updates</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        View all guides
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
