---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { slugifyTag } from "@/utils/tagSlug";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// 5 primary categories — tag values must match article frontmatter tags.
// Icons are lucide-style inline SVGs rendered via <Fragment set:html>.
const categories = [
  {
    name: "Universities",
    desc: "Go8, ATN, rankings",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  },
  {
    name: "Courses",
    desc: "Business, STEM, Health",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    name: "Visa",
    desc: "Subclass 500, GS, IELTS",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 5-4 9-9 9s-9-4-9-9 4-9 9-9c1.6 0 3.2.4 4.5 1.2"/></svg>`,
  },
  {
    name: "Living",
    desc: "Housing, OSHC, costs",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10l9-7 9 7v10a2 2 0 0 1-2 2h-4v-7h-6v7H5a2 2 0 0 1-2-2z"/></svg>`,
  },
  {
    name: "Post-Study",
    desc: "485 visa, PR, jobs",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Your complete guide to studying in Australia.
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="RSS feed"
        title="RSS feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS feed</span>
      </a>

      <p>
        <strong>StudyAU</strong> is a plain-English knowledge base for international
        students planning to study in Australia — from Group of Eight and ATN
        university selection, to the Student Visa (subclass 500), Genuine Student
        requirement, IELTS/PTE pathways, accommodation, cost of living, and the
        Temporary Graduate Visa (subclass 485). We work from Department of Home
        Affairs, Department of Education, and university sources, and we update
        whenever policy changes.
      </p>
      <p class="mt-2">
        Browse a category below or read
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/about/"
        >
          about this site
        </LinkButton> for our editorial approach.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Contact:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="categories" class="pt-12 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide">Browse by category</h2>
      <ul class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {categories.map(c => (
          <li>
            <a
              href={`/tags/${slugifyTag(c.name)}/`}
              class="group flex h-full flex-col gap-2 rounded-lg border border-border px-4 py-4 transition hover:-translate-y-0.5 hover:border-accent hover:shadow-sm focus-visible:border-accent"
            >
              <span
                class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-accent/10 text-accent transition group-hover:bg-accent group-hover:text-background"
                aria-hidden="true"
              >
                <Fragment set:html={c.icon} />
              </span>
              <span class="text-sm font-semibold leading-tight whitespace-nowrap text-foreground group-hover:text-accent">
                {c.name}
              </span>
              <span class="text-xs leading-snug text-foreground/60">
                {c.desc}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured guides</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent updates</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        View all guides
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
