---
import { ClientRouter } from "astro:transitions";
import {
  PUBLIC_GOOGLE_SITE_VERIFICATION,
  PUBLIC_BING_VERIFICATION,
  PUBLIC_BAIDU_VERIFICATION,
  PUBLIC_SOGOU_VERIFICATION,
  PUBLIC_360_VERIFICATION,
  PUBLIC_SHENMA_VERIFICATION,
  PUBLIC_TOUTIAO_VERIFICATION,
} from "astro:env/client";
import { SITE } from "@/config";
import FloatingActions from "@/components/FloatingActions.astro";
import "@/styles/global.css";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  tags?: string[];
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  tags,
} = Astro.props;

// Some search engines + AI crawlers still read meta keywords.
// Article pages use the article's own tags; non-article pages use the site-wide topic list.
const metaKeywords =
  tags && tags.length > 0
    ? tags.join(", ")
    : "study in Australia, Australian universities, Group of Eight, Student Visa 500, Genuine Student, IELTS, scholarships, Post-Study Work Visa, international students, applying to Australia";

const socialImageURL = new URL(ogImage, Astro.url);

// Article pages (with pubDatetime) emit both BlogPosting and QAPage structured data:
// - BlogPosting tells Google + social networks this is an article
// - QAPage tells AI crawlers (ChatGPT / Perplexity / Gemini) that the page
//   is a single Q&A: title = question, body = answer.
const isPost = Boolean(pubDatetime);

const blogPostingSchema = isPost
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: `${title}`,
      image: `${socialImageURL}`,
      datePublished: pubDatetime!.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: `${author}`,
          ...(profile && { url: profile }),
        },
      ],
    }
  : null;

const qaPageSchema = isPost
  ? {
      "@context": "https://schema.org",
      "@type": "QAPage",
      mainEntity: {
        "@type": "Question",
        name: `${title}`,
        text: `${title}`,
        answerCount: 1,
        acceptedAnswer: {
          "@type": "Answer",
          text: `${description}`,
          url: `${canonicalURL}`,
          dateCreated: `${pubDatetime?.toISOString()}`,
          author: {
            "@type": "Organization",
            name: `${SITE.author}`,
            url: SITE.website,
          },
        },
      },
    }
  : null;

// Non-article pages (home / about / tags etc.) emit WebSite + Organization
// structured data so Google can build a brand knowledge panel and SiteLinks search box.
const websiteSchema = !isPost
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      alternateName: "Study in Australia",
      url: SITE.website,
      inLanguage: SITE.lang,
      description: SITE.desc,
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${SITE.website.replace(/\/$/, "")}/search?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
      publisher: {
        "@type": "Organization",
        name: SITE.author,
        url: SITE.website,
      },
    }
  : null;

const organizationSchema = !isPost
  ? {
      "@context": "https://schema.org",
      "@type": "Organization",
      name: SITE.author,
      alternateName: "Study in Australia",
      url: SITE.website,
      logo: new URL("/favicon.svg", SITE.website).toString(),
      description: SITE.desc,
      sameAs: [] as string[],
      knowsAbout: [
        "Study in Australia",
        "Australian universities",
        "Group of Eight (Go8)",
        "Australian Technology Network (ATN)",
        "University admissions Australia",
        "Student Visa subclass 500",
        "Genuine Student (GS) requirement",
        "IELTS / PTE / TOEFL",
        "Australia Awards Scholarships",
        "Post-Study Work Visa subclass 485",
        "Temporary Graduate Visa",
        "Student accommodation Australia",
        "OSHC overseas student health cover",
      ],
    }
  : null;
---

<!doctype html>
<html
  dir={SITE.dir}
  lang=`${SITE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Icons: modern browsers use SVG, legacy fallbacks use ICO/PNG -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />


    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={metaKeywords} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- JSON-LD structured data for search engines -->
    {
      blogPostingSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(blogPostingSchema)}
        />
      )
    }
    {
      qaPageSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(qaPageSchema)}
        />
      )
    }
    {
      websiteSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(websiteSchema)}
        />
      )
    }
    {
      organizationSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(organizationSchema)}
        />
      )
    }

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    <!-- Search engine site-verification tags (only emitted if env vars are set) -->
    {
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }
    {
      PUBLIC_BING_VERIFICATION && (
        <meta name="msvalidate.01" content={PUBLIC_BING_VERIFICATION} />
      )
    }
    {
      PUBLIC_BAIDU_VERIFICATION && (
        <meta
          name="baidu-site-verification"
          content={PUBLIC_BAIDU_VERIFICATION}
        />
      )
    }
    {
      PUBLIC_SOGOU_VERIFICATION && (
        <meta
          name="sogou_site_verification"
          content={PUBLIC_SOGOU_VERIFICATION}
        />
      )
    }
    {
      PUBLIC_360_VERIFICATION && (
        <meta name="360-site-verification" content={PUBLIC_360_VERIFICATION} />
      )
    }
    {
      PUBLIC_SHENMA_VERIFICATION && (
        <meta
          name="shenma-site-verification"
          content={PUBLIC_SHENMA_VERIFICATION}
        />
      )
    }
    {
      PUBLIC_TOUTIAO_VERIFICATION && (
        <meta
          name="bytedance-verification-code"
          content={PUBLIC_TOUTIAO_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Global floating CTA in the bottom-right: free university assessment -->
    <FloatingActions />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
