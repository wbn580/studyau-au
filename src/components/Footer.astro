---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const footerLinks = [
  { label: "About", href: "/about/" },
  { label: "Resources", href: "/resources/" },
  { label: "Sitemap", href: "/sitemap/" },
  { label: "Privacy", href: "/privacy/" },
  { label: "Disclaimer", href: "/disclaimer/" },
  { label: "RSS", href: "/rss.xml" },
];
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-4",
      "border-t border-border",
      "flex flex-col items-center gap-3",
    ]}
  >
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm">
        {
          footerLinks.map(link => (
            <li>
              <a href={link.href} class="hover:text-accent hover:underline">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div
      class="flex w-full flex-col items-center justify-between gap-2 sm:flex-row-reverse"
    >
      <Socials />
      <div class="flex flex-col items-center whitespace-nowrap sm:flex-row">
        <span>&#169; {currentYear} StudyAU</span>
        <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
        <span>All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>
